{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "salah-api-proxy",
  "main": "worker.mjs",
  "compatibility_date": "2026-07-07",
  "secrets": {
    "required": [
      "ORIGIN_TOKEN"
    ]
  },
  "routes": [
    {
      "pattern": "api.salah.abdlh.com",
      "custom_domain": true
    }
  ]
}
