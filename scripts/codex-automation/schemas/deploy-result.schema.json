{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salah.abdlh.com/schemas/codex-automation/deploy-result.schema.json",
  "title": "Salah Improvement Deploy Result",
  "x-result-kind": "deploy-result",
  "type": "object",
  "required": [
    "stop_state",
    "summary",
    "evidence",
    "checks",
    "selected_issue",
    "branch",
    "verification",
    "deploy",
    "blockers"
  ],
  "properties": {
    "stop_state": {
      "type": "string",
      "enum": ["clean-no-op", "prepared-fix", "blocked", "deployed"]
    },
    "summary": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": ["object", "string"]
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped", "blocked"]
          },
          "log": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "selected_issue": {
      "type": ["object", "null"],
      "properties": {
        "url": { "type": "string" },
        "number": { "type": ["number", "string"] },
        "title": { "type": "string" }
      },
      "additionalProperties": true
    },
    "branch": { "type": ["string", "null"] },
    "verification": {
      "type": "array",
      "items": {
        "type": ["object", "string"]
      }
    },
    "deploy": {
      "type": ["object", "null"],
      "properties": {
        "live_url": { "type": "string" },
        "commit_or_merge": { "type": "string" },
        "target": { "type": "string" }
      },
      "additionalProperties": true
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["area", "detail", "next_step"],
        "properties": {
          "area": { "type": "string" },
          "detail": { "type": "string" },
          "next_step": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
