{
  "name": "salah",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api:apns:check": "npm run api:build && node dist-api/apnsSmoke.js",
    "api:build": "tsc -p tsconfig.api.json",
    "api:start": "node dist-api/index.js",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:mobile": "npm run build && playwright test e2e/mobile.spec.ts --project=mobile-chrome --project=mobile-webkit",
    "test:mobile:webkit": "npm run build && playwright test e2e/mobile.spec.ts --project=mobile-webkit",
    "test:pwa": "npm run build && playwright test e2e/pwa.spec.ts --project=pwa-chromium",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "adhan": "^4.4.4",
    "fastify": "^5.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
